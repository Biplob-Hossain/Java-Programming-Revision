import  java.util.Scanner;
public class SumEvenNNumber {
    public static void main(String[] args) {

        int num ,i;
        System.out.println("Enter your number to get sum of Even \n");

        Scanner sc =new Scanner(System.in);

        num=sc.nextInt();
        int sum=0;
        for ( i=2; i <=num; i+=2)
        {
           sum+=i;
        }
        System.out.println("Sum of Even  of your number is  "+sum);
    }
}
