import java.util.Scanner;
public class SumLoop {
    public static void main(String[] args) {

        System.out.println("Print N number to sum");
        Scanner sc = new Scanner(System.in);

        int num=sc.nextInt();
        int sum=0;
        for (int i=1; i <=num; i++)
        {
            sum=sum+i;
        }
        System.out.println("sum of your number is "+sum);
    }
}
