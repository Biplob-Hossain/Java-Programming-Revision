import java.util.Scanner;
public class SumOfDigit {
    public static void main(String[] args) {

        int N, temp, rem,sum=0;

        Scanner sc =new Scanner(System.in);

        N=sc.nextInt();
        temp=N;
        while (temp!=0)
        {
            rem=temp%10;
            sum=sum+rem;
            temp=temp/10;
        }
        System.out.println("Sum of your Digit is %d "+sum);
    }

}
