import java.util.Scanner;
public class ReverseDigit {
    public static void main(String[] args) {

        int N, temp, rem,sum=0;

        System.out.println("Enter any Digit for Reverse\n");
        Scanner sc =new Scanner(System.in);

        N=sc.nextInt();
        temp=N;
        while (temp!=0)
        {
            rem=temp%10;
            sum=sum*10+rem;
            temp=temp/10;
        }
        System.out.println("Reverse of your Digit is  "+sum);
    }

}
