public class Swapping {

    public static void main(String[] args) {

        int num1 = 10, num2 = 20, swap;

        System.out.printf("Befor swapping value of two number is \n%d\n%d\n", num1, num2);
        swap = num1;
        num1 = num2;
        num2 = swap;

        System.out.printf("After swapping value of two number is \n%d\n%d", num1, num2);
    }
}
